# ─────────────────────────────────────────────────────────────────────────────
# Riverwood AI Voice Agent — Environment Variables
# Copy this to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────


# ── Twilio (PSTN connectivity) ────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC41f1607fb935627...
TWILIO_AUTH_TOKEN=527a...
TWILIO_PHONE_NUMBER=+19045...
MY_PHONE_NUMBER=+917903...        # Destination number for test calls


# ── VAPI (Primary telephony + WebRTC + ElevenLabs TTS orchestration) ──────────
VAPI_API_KEY=9368...
# Your VAPI phone number ID — find in VAPI dashboard → Phone Numbers
# Link your Twilio number there and paste the VAPI ID here.
VAPI_PHONE_NUMBER_ID=vapi-phone-number-uuid-here


# ── OpenAI (LLM — GPT-4o-mini for fast, cost-efficient streaming) ─────────────
OPENAI_API_KEY=sk-svc...


# ── ElevenLabs (Voice ID used by VAPI for TTS) ────────────────────────────────
ELEVEN_LABS_KEY=sk_e50...
# Voice ID for Ravi — choose a warm Indian-accent English voice from:
# https://elevenlabs.io/voice-library
# Good defaults:
#   "ThT5KcBeYPX3keUQqHPh" — Aria (American, warm)
#   "21m00Tcm4TlvDq8ikWAM" — Rachel (warm, clear)
#   "AZnzlk1XvdvUeBnXmlld" — Domi (energetic)
# Clone a custom voice for maximum brand authenticity.
ELEVEN_LABS_VOICE_ID=ThT5KcBeYPX3keUQqHPh


# ── Server / Tunnelling ────────────────────────────────────────────────────────
# Your public URL — ngrok, Cloudflare Tunnel, or deployed domain.
# VAPI and Twilio will POST to {NGROK_URL}/api/vapi-webhook
NGROK_URL=https://mariano-servable-gratulatorily.ngrok-free.dev


# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./riverwood.db
# For production, switch to Postgres:
# DATABASE_URL=postgresql://user:password@localhost/riverwood


# ── Redis (Hot memory cache + Celery broker) ───────────────────────────────────
REDIS_URL=redis://localhost:6379/0


# ── Storage ────────────────────────────────────────────────────────────────────
TTS_OUTPUT_DIR=./audio


# ── Development flags ──────────────────────────────────────────────────────────
# Set to "true" to skip all external API calls (local testing)
SIMULATE_TELEPHONY=false


# ── Legacy Gemini (no longer primary — kept for reference) ────────────────────
# GEMMA_API_KEY=AIzaSyA...
